---
export interface FileMeta {
  id: string;
  filename: string;
  accent?: string;
  watermark?: string;
  group?: string;
}
interface Props {
  files: FileMeta[];
}
const { files } = Astro.props;
const first = files[0];
const metaJson = JSON.stringify(
  files.map((f) => ({ id: f.id, filename: f.filename, accent: f.accent ?? '', watermark: f.watermark ?? '' })),
);
---

<div class="editor" data-editor data-sidebar="">
  <aside class="editor__sidebar" id="sidebar">
    <slot name="sidebar" />
  </aside>
  <div class="editor__scrim" data-sidebar-toggle aria-hidden="true"></div>

  <div class="editor__main">
    <!-- Mobile-only control bar -->
    <div class="mobilebar">
      <button class="icon-btn" data-sidebar-toggle aria-label="Toggle explorer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"></path>
        </svg>
      </button>
      <span class="mobilebar__crumb" style="color:var(--muted);font-size:13px">~/zara</span>
      <button class="icon-btn" data-theme-toggle aria-label="Toggle theme" style="margin-left:auto">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>

    <!-- Dynamic file tabs (opened from the Explorer) -->
    <div class="tabbar">
      <div class="tabbar__tabs" role="tablist">
        {
          first && (
            <button class="tab" role="tab" data-file-tab={first.id} aria-selected="true" style={first.accent ? `--tab-accent:${first.accent}` : undefined}>
              <span class="tab__name">{first.filename}</span>
              <span class="tab__close" data-close aria-label="Close">&times;</span>
            </button>
          )
        }
      </div>
      <div class="tabbar__actions">
        <button class="icon-btn" data-sidebar-toggle aria-label="Toggle sidebar">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="3" y="4" width="18" height="16" rx="2"></rect>
            <path d="M9 4v16"></path>
          </svg>
        </button>
        <button class="icon-btn" data-theme-toggle aria-label="Toggle theme">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" stroke-linecap="round"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Active file body -->
    <div class="editor__body" id="editor-body" data-watermark={first?.watermark ?? ''}>
      <div class="editor__empty" data-show="false">
        <p class="code-comment">// no file open — pick one from the Explorer in the sidebar.</p>
      </div>
      <slot name="files" />
    </div>
  </div>
</div>

<script type="application/json" id="files-meta" set:html={metaJson}></script>

<script>
  const editor = document.querySelector('[data-editor]');
  const tabsContainer = document.querySelector('.tabbar__tabs');
  const body = document.getElementById('editor-body');
  const emptyEl = document.querySelector('.editor__empty');
  const treeItems = Array.from(document.querySelectorAll('[data-file-open]'));

  const rawMeta = document.getElementById('files-meta')?.textContent || '[]';
  const metaList = JSON.parse(rawMeta);
  const metaById = Object.fromEntries(metaList.map((m) => [m.id, m]));

  const setEmpty = (show) => { if (emptyEl) emptyEl.dataset.show = String(show); };
  const panels = () => Array.from(document.querySelectorAll('.file[data-file]'));

  // Clone a file's content from its <template> the first time it opens (keeps
  // the live DOM tiny — only the active/open files exist as real nodes).
  function ensurePanel(id) {
    let panel = document.querySelector(`.file[data-file="${CSS.escape(id)}"]`);
    if (panel) return panel;
    const tpl = document.querySelector(`template[data-file-tpl="${CSS.escape(id)}"]`);
    if (!tpl || !body) return null;
    panel = document.createElement('div');
    panel.className = 'file';
    panel.dataset.file = id;
    panel.hidden = true;
    panel.appendChild(tpl.content.cloneNode(true));
    body.appendChild(panel);
    return panel;
  }

  const STORE_KEY = 'zara-editor-state';
  function saveState() {
    if (!tabsContainer) return;
    const open = Array.from(tabsContainer.querySelectorAll('[data-file-tab]')).map((t) => t.dataset.fileTab);
    const active = tabsContainer.querySelector('[data-file-tab][aria-selected="true"]')?.dataset.fileTab || null;
    try { localStorage.setItem(STORE_KEY, JSON.stringify({ open, active })); } catch (e) {}
  }

  function activate(id) {
    if (!tabsContainer) return;
    Array.from(tabsContainer.querySelectorAll('[data-file-tab]')).forEach((t) =>
      t.setAttribute('aria-selected', String(t.dataset.fileTab === id)));
    panels().forEach((f) => { f.hidden = f.dataset.file !== id; });
    if (body) body.dataset.watermark = metaById[id]?.watermark || '';
    treeItems.forEach((t) => t.classList.toggle('is-active', t.dataset.fileOpen === id));
    setEmpty(false);
    body?.scrollTo({ top: 0 });
    saveState();
  }

  function openFile(id) {
    const m = metaById[id];
    if (!m || !tabsContainer) return;
    ensurePanel(id);
    let tab = tabsContainer.querySelector(`[data-file-tab="${CSS.escape(id)}"]`);
    if (!tab) {
      tab = document.createElement('button');
      tab.className = 'tab';
      tab.setAttribute('role', 'tab');
      tab.dataset.fileTab = id;
      if (m.accent) tab.style.setProperty('--tab-accent', m.accent);
      const name = document.createElement('span');
      name.className = 'tab__name';
      name.textContent = m.filename;
      const close = document.createElement('span');
      close.className = 'tab__close';
      close.dataset.close = '';
      close.setAttribute('aria-label', 'Close');
      close.textContent = '\u00d7';
      tab.append(name, close);
      tabsContainer.appendChild(tab);
    }
    activate(id);
    tab.scrollIntoView({ inline: 'nearest', block: 'nearest' });
  }

  function closeTab(id) {
    if (!tabsContainer) return;
    const tab = tabsContainer.querySelector(`[data-file-tab="${CSS.escape(id)}"]`);
    if (!tab) return;
    const wasActive = tab.getAttribute('aria-selected') === 'true';
    const next = tab.nextElementSibling || tab.previousElementSibling;
    tab.remove();
    // Free the DOM for closed files (readme is the live default — keep it).
    const panel = document.querySelector(`.file[data-file="${CSS.escape(id)}"]`);
    if (panel && id !== 'readme') panel.remove();
    if (wasActive) {
      if (next && next.dataset.fileTab) {
        activate(next.dataset.fileTab);
      } else {
        panels().forEach((f) => (f.hidden = true));
        treeItems.forEach((t) => t.classList.remove('is-active'));
        if (body) body.dataset.watermark = '';
        setEmpty(true);
      }
    }
    saveState();
  }

  // Tab bar: activate on click, close on the × button.
  tabsContainer?.addEventListener('click', (e) => {
    const target = e.target;
    const tab = target.closest('[data-file-tab]');
    if (!tab || !tab.dataset.fileTab) return;
    if (target.closest('[data-close]')) closeTab(tab.dataset.fileTab);
    else activate(tab.dataset.fileTab);
  });

  // Explorer: toggle folders, open files.
  document.addEventListener('click', (e) => {
    const target = e.target;
    const folderLabel = target.closest('.tree-folder__label');
    if (folderLabel) {
      const folder = folderLabel.closest('.tree-folder');
      if (folder) folder.dataset.collapsed = folder.dataset.collapsed === 'true' ? 'false' : 'true';
      return;
    }
    const fileBtn = target.closest('[data-file-open]');
    if (fileBtn && fileBtn.dataset.fileOpen) {
      openFile(fileBtn.dataset.fileOpen);
      if (window.matchMedia('(max-width: 860px)').matches) editor?.setAttribute('data-sidebar', '');
    }
  });

  // Theme toggle (persisted)
  document.querySelectorAll('[data-theme-toggle]').forEach((b) =>
    b.addEventListener('click', () => {
      const cur = document.documentElement.getAttribute('data-theme') || 'dark';
      const next = cur === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (e) {}
    }),
  );

  // Sidebar collapse (desktop) / open (mobile)
  document.querySelectorAll('[data-sidebar-toggle]').forEach((b) =>
    b.addEventListener('click', () => {
      if (!editor) return;
      const isMobile = window.matchMedia('(max-width: 860px)').matches;
      const cur = editor.getAttribute('data-sidebar') || '';
      if (isMobile) editor.setAttribute('data-sidebar', cur === 'open' ? '' : 'open');
      else editor.setAttribute('data-sidebar', cur === 'collapsed' ? '' : 'collapsed');
    }),
  );

  // Restore the last session (open tabs + active file), else deep-link, else first file.
  let restored = false;
  try {
    const saved = JSON.parse(localStorage.getItem(STORE_KEY) || 'null');
    if (saved && Array.isArray(saved.open) && saved.open.length) {
      saved.open.filter((id) => metaById[id]).forEach((id) => openFile(id));
      const active = saved.active && metaById[saved.active] ? saved.active : saved.open[0];
      if (active) activate(active);
      restored = true;
    }
  } catch (e) {}

  if (!restored) {
    const hash = location.hash.replace('#file-', '');
    const initial = hash && metaById[hash] ? hash : metaList[0]?.id;
    if (initial) openFile(initial);
  }
</script>
