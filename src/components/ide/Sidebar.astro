---
import { identity, heroParagraphs, facts } from '@/data/bio.js';
import { social } from '@/data/social.js';
import type { FileMeta } from '@/components/ide/EditorShell.astro';

interface Props {
  files: FileMeta[];
}
const { files } = Astro.props;

const readmeFile = files.find((f) => f.id === 'readme');
const projectsFiles = files.filter((f) => f.group === 'projects');
const otherFiles = files.filter((f) => !f.group && f.id !== 'readme');

const strip = (s: string) =>
  s.replace(/<br\s*\/?>/gi, ' ').replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
const paras = heroParagraphs.map(strip);

// Quick-facts subset kept in the profile.
const factKeys = ['Location', 'Experience', 'Superpower', 'Reading', 'Favorite Matcha', 'Currently Building'];
const factList = facts
  .filter((f) => factKeys.includes(f.heading))
  .map((f) => ({ heading: f.heading, value: f.lines.join(' · ') }));

const keyFor: Record<string, string> = {
  Email: 'email',
  Github: 'github',
  Medium: 'medium',
  Twitter: 'twitter',
  LinkedIn: 'linkedin',
};
const contact = social.map((s) => ({
  key: keyFor[s.label] ?? s.label.toLowerCase(),
  href: s.href,
  display: s.href.replace(/^mailto:/, '').replace(/^https?:\/\//, '').replace(/\/$/, ''),
}));
---

<!-- Collapsed rail: keeps Profile/Contact reachable on the left -->
<div class="side-rail" aria-label="Collapsed sidebar">
  <button class="side-rail__btn" data-sidebar-toggle aria-label="Expand sidebar" title="Expand sidebar">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </button>
  <button class="side-rail__btn" data-rail-expand="profile" aria-label="Open Profile" title="Profile" aria-current="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <circle cx="12" cy="8" r="3.5"></circle>
      <path d="M5 20c0-3.3 3.1-6 7-6s7 2.7 7 6" stroke-linecap="round"></path>
    </svg>
  </button>
  <button class="side-rail__btn" data-rail-expand="contact" aria-label="Open Contact" title="Contact">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <rect x="3" y="5" width="18" height="14" rx="2"></rect>
      <path d="M4 7l8 6 8-6" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </button>
</div>

<!-- Full sidebar -->
<div class="side-full">
  <span class="side-watermark" id="side-watermark" aria-hidden="true">profile</span>

  <div class="side-head" role="tablist" aria-label="Profile panels">
    <button class="side-tab" role="tab" data-side-tab="profile" aria-selected="true">Profile</button>
    <button class="side-tab" role="tab" data-side-tab="contact" aria-selected="false">Contact</button>
    <button class="side-close" data-sidebar-toggle aria-label="Collapse sidebar" title="Collapse sidebar">&times;</button>
  </div>

  <div class="side-body">
    <!-- Profile — full bio (moved from readme) + quick facts -->
    <div class="side-panel" data-side-panel="profile">
      <div class="src">
        <div><span class="comment">&lt;!-- start .scope-profile --&gt;</span></div>
        <div><span class="tag">&lt;section</span> <span class="attr">class</span>=<span class="string">"scope-profile"</span><span class="tag">&gt;</span></div>
        <div class="indent1"><span class="tag">&lt;h1&gt;</span> <span class="txt">{identity.name}</span> <span class="tag">&lt;/h1&gt;</span></div>
        <div class="indent1"><span class="tag">&lt;h3&gt;</span> <span class="txt">{identity.tagline}</span> <span class="tag">&lt;/h3&gt;</span></div>
        {
          paras.map((p) => (
            <div class="indent1 gap"><span class="tag">&lt;p&gt;</span> <span class="txt">{p}</span> <span class="tag">&lt;/p&gt;</span></div>
          ))
        }
        <div class="indent1 gap"><span class="comment">&lt;!-- quick facts --&gt;</span></div>
        <div class="indent1"><span class="tag">&lt;ul&gt;</span></div>
        {
          factList.map((f) => (
            <div class="indent2 gap"><span class="tag">&lt;li&gt;</span> <span class="attr">{f.heading}</span>: <span class="txt">{f.value}</span> <span class="tag">&lt;/li&gt;</span></div>
          ))
        }
        <div class="indent1"><span class="tag">&lt;/ul&gt;</span></div>
        <div><span class="tag">&lt;/section&gt;</span></div>
      </div>
    </div>

    <!-- Contact -->
    <div class="side-panel" data-side-panel="contact" hidden>
      <div class="src">
        <div><span class="comment">// contact.js</span></div>
        <div><span class="key">const</span> <span class="txt">contact</span> = {'{'}</div>
        {
          contact.map((c) => (
            <div class="indent1 gap"><span class="attr">{c.key}</span>: <a class="string" href={c.href} target={c.href.startsWith('mailto:') ? undefined : '_blank'} rel="noopener noreferrer">"{c.display}"</a>,</div>
          ))
        }
        <div>{'}'};</div>
        <div class="gap"><span class="key">export default</span> <span class="txt">contact</span>;</div>
      </div>
    </div>
  </div>

  <!-- File explorer: click a file to open it as a tab -->
  <div class="side-explorer">
    <div class="side-explorer__head">Explorer</div>
    <div class="tree" role="tree">
      <div class="tree__root">zara/</div>
      {
        readmeFile && (
          <button class="tree-item" data-file-open={readmeFile.id} role="treeitem">
            <span class="tree-item__dot" style={`--tree-accent:${readmeFile.accent}`} />
            <span class="tree-item__name">{readmeFile.filename}</span>
          </button>
        )
      }
      <div class="tree-folder" data-collapsed="false">
        <button class="tree-folder__label" aria-label="Toggle projects folder">
          <svg class="tree-folder__chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          <span>projects/</span>
        </button>
        <div class="tree-folder__items">
          {
            projectsFiles.map((f) => (
              <button class="tree-item" data-file-open={f.id} role="treeitem">
                <span class="tree-item__dot" style={`--tree-accent:${f.accent}`} />
                <span class="tree-item__name">{f.filename}</span>
              </button>
            ))
          }
        </div>
      </div>
      {
        otherFiles.map((f) => (
          <button class="tree-item" data-file-open={f.id} role="treeitem">
            <span class="tree-item__dot" style={`--tree-accent:${f.accent}`} />
            <span class="tree-item__name">{f.filename}</span>
          </button>
        ))
      }
    </div>
  </div>
</div>

<script>
  const editor = document.querySelector<HTMLElement>('[data-editor]');
  const sideTabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-side-tab]'));
  const sidePanels = Array.from(document.querySelectorAll<HTMLElement>('[data-side-panel]'));
  const railBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-rail-expand]'));
  const watermark = document.getElementById('side-watermark');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  // Reveal character-by-character (typewriter) without layout shift.
  function revealTypewriter(container: HTMLElement) {
    const runId = Date.now().toString() + Math.random().toString();
    container.dataset.typeRun = runId;

    if (!container.dataset.orig) container.dataset.orig = container.innerHTML;
    container.innerHTML = container.dataset.orig;
    
    if (reduceMotion) return;

    const walker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT, null);
    const textNodes: Text[] = [];
    let node: Node | null;
    while ((node = walker.nextNode())) textNodes.push(node as Text);

    const chars: HTMLElement[] = [];
    for (const tn of textNodes) {
      const text = tn.nodeValue || '';
      if (!text.trim()) continue;
      const frag = document.createDocumentFragment();
      for (const char of text) {
        if (char === ' ' || char === '\n') {
          frag.appendChild(document.createTextNode(char));
        } else {
          const span = document.createElement('span');
          span.textContent = char;
          span.style.visibility = 'hidden';
          frag.appendChild(span);
          chars.push(span);
        }
      }
      tn.parentNode?.replaceChild(frag, tn);
    }

    const duration = 1200; // ms
    let startTime: number | null = null;
    let i = 0;

    function typeFrame(now: number) {
      if (container.dataset.typeRun !== runId) return; // Cancelled by new run
      if (!startTime) startTime = now;
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const targetIdx = Math.floor(progress * chars.length);
      
      while (i < targetIdx) {
        chars[i].style.visibility = 'visible';
        i++;
      }
      
      if (progress < 1) {
        requestAnimationFrame(typeFrame);
      }
    }
    requestAnimationFrame(typeFrame);
  }

  function selectPanel(id: string | undefined) {
    if (!id) return;
    sideTabs.forEach((x) => x.setAttribute('aria-selected', String(x.dataset.sideTab === id)));
    sidePanels.forEach((p) => {
      const isSelected = p.dataset.sidePanel === id;
      p.hidden = !isSelected;
      if (isSelected) {
        const src = p.querySelector<HTMLElement>('.src');
        if (src) revealTypewriter(src);
      } else {
        const src = p.querySelector<HTMLElement>('.src');
        if (src) src.dataset.typeRun = ''; // Cancel typing
      }
    });
    if (watermark) watermark.textContent = id;
    railBtns.forEach((b) => b.setAttribute('aria-current', String(b.dataset.railExpand === id)));
  }

  sideTabs.forEach((t) => t.addEventListener('click', () => selectPanel(t.dataset.sideTab)));

  railBtns.forEach((b) =>
    b.addEventListener('click', () => {
      editor?.setAttribute('data-sidebar', '');
      selectPanel(b.dataset.railExpand);
    }),
  );
</script>
